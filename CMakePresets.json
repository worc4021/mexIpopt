{
    "version": 6,
    "configurePresets": [
        {
            "name": "config-base",
            "generator": "Ninja",
            "hidden": true,
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}"
        },
        {
            "name": "windows-config-base",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux-config-base",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "macos-config-base",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "unix-based-config-base",
            "hidden": true,
            "condition": {
                "type": "inList",
                "string": "${hostSystemName}",
                "list": ["Linux","Darwin"]
            }
        },
        {
            "name": "config-debug-base",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "config-release-base",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "windows-intel-base",
            "inherits": ["config-base","windows-config-base"],
            "displayName": "Intel oneAPI base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "icx-cl",
                "CMAKE_CXX_COMPILER": "icx-cl"
            },
            "hidden": true
        },
        {
            "name": "windows-msvc-base",
            "inherits": ["config-base","windows-config-base"],
            "displayName": "MSVC base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl",
                "CMAKE_CXX_COMPILER": "cl"
            },
            "hidden": true
        },
        {
            "name": "gcc-14-base",
            "inherits": "config-base",
            "displayName": "GCC 14 base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc-14",
                "CMAKE_CXX_COMPILER": "g++-14"
            },
            "hidden": true
        },
        {
            "name": "gcc-15-base",
            "inherits": "config-base",
            "displayName": "GCC 15 base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc-15",
                "CMAKE_CXX_COMPILER": "g++-15"
            },
            "hidden": true
        },
        {
            "name": "gcc-mingw-base",
            "inherits": ["config-base","windows-config-base"],
            "displayName": "GCC MinGW base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_Fortran_COMPILER": "gfortran",
                "IPOPT_PREFIX": "C:/repos/Ipopt/build/mingw"
            },
            "hidden": true
        },
        {
            "name": "icx-compiler-base",
            "inherits": "config-base",
            "displayName": "Intel oneAPI base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "icx",
                "CMAKE_CXX_COMPILER": "icpx"
            },
            "hidden": true
        },
        {
            "name": "windows-intel-debug-config",
            "displayName": "Intel oneAPI Debug",
            "inherits": ["windows-intel-base","config-debug-base"]
        },
        {
            "name": "windows-intel-release-config",
            "displayName": "Intel oneAPI Release",
            "inherits": ["windows-intel-base","config-release-base"]
        },
        {
            "name": "windows-msvc-debug-config",
            "displayName": "MSVC Debug",
            "inherits": ["windows-msvc-base","config-debug-base"]
        },
        {
            "name": "windows-msvc-release-config",
            "displayName": "MSVC Release",
            "inherits": ["windows-msvc-base","config-release-base"]
        },
        {
            "name": "gcc-14-release-config",
            "displayName": "GCC 14 Release",
            "inherits": ["unix-based-config-base","gcc-14-base","config-release-base"]
        },
        {
            "name": "gcc-14-debug-config",
            "displayName": "GCC 14 Debug",
            "inherits": ["unix-based-config-base","gcc-14-base","config-debug-base"]
        },
        {
            "name": "gcc-15-release-config",
            "displayName": "GCC 15 Release",
            "inherits": ["unix-based-config-base","gcc-15-base","config-release-base"]
        },
        {
            "name": "gcc-15-debug-config",
            "displayName": "GCC 15 Debug",
            "inherits": ["unix-based-config-base","gcc-15-base","config-debug-base"]
        },
        {
            "name": "windows-gcc-release-config",
            "displayName": "MinGw GCC Release",
            "inherits": ["gcc-mingw-base","config-release-base"]
        },
        {
            "name": "windows-gcc-debug-config",
            "displayName": "MinGw GCC Debug",
            "inherits": ["gcc-mingw-base","config-debug-base"]
        },
        {
            "name": "intel-release-config",
            "displayName": "Intel Release",
            "inherits": ["icx-compiler-base","unix-based-config-base","config-release-base"]
        },
        {
            "name": "intel-debug-config",
            "displayName": "Intel Debug",
            "inherits": ["icx-compiler-base","unix-based-config-base","config-debug-base"]
        }
    ],
    "buildPresets": [
        {
            "name": "windows-intel-debug-build",
            "configurePreset": "windows-intel-debug-config",
            "displayName": "Intel oneAPI Debug"
        },
        {
            "name": "windows-intel-release-build",
            "configurePreset": "windows-intel-release-config",
            "displayName": "Intel oneAPI Release"            
        },
        {
            "name": "gcc-14-release-build",
            "configurePreset": "gcc-14-release-config",
            "displayName": "GCC 14 Release"
        },
        {
            "name": "gcc-14-debug-build",
            "configurePreset": "gcc-14-debug-config",
            "displayName": "GCC 14 Debug"
        },
        {
            "name": "gcc-15-release-build",
            "configurePreset": "gcc-15-release-config",
            "displayName": "GCC 15 Release"
        },
        {
            "name": "gcc-15-debug-build",
            "configurePreset": "gcc-15-debug-config",
            "displayName": "GCC 15 Debug"
        },
        {
            "name": "windows-gcc-release-build",
            "configurePreset": "windows-gcc-release-config",
            "displayName": "MinGW GCC Release"
        },
        {
            "name": "windows-gcc-debug-build",
            "configurePreset": "windows-gcc-debug-config",
            "displayName": "MinGW GCC Debug"
        },
        {
            "name": "intel-release-build",
            "configurePreset": "intel-release-config",
            "displayName": "Intel Release"
        },
        {
            "name": "intel-debug-build",
            "configurePreset": "intel-debug-config",
            "displayName": "Intel Debug"
        }
    ],
    "testPresets": [
        {
            "name": "test-base",
            "hidden": true,
            "output": {"outputOnFailure": true},
            "execution": {
                "noTestsAction": "error", 
                "stopOnFailure": false
            }
        },
        {
            "name": "windows-intel-release-test",
            "inherits": "test-base",
            "configurePreset": "windows-intel-release-config",
            "displayName": "Intel oneAPI Release"
        },
        {
            "name": "gcc-14-release-test",
            "inherits": "test-base",
            "configurePreset": "gcc-14-release-config",
            "displayName": "GCC 14 Release"
        },
        {
            "name": "gcc-15-release-test",
            "inherits": "test-base",
            "configurePreset": "gcc-15-release-config",
            "displayName": "GCC 15 Release"
        },
        {
            "name": "intel-release-test",
            "inherits": "test-base",
            "configurePreset": "intel-release-config",
            "displayName": "Intel Release"
        },
        {
            "name": "windows-gcc-release-test",
            "inherits": "test-base",
            "configurePreset": "windows-gcc-release-config",
            "displayName": "MinGW GCC Release"
        }
    ]
}